# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase — find these in your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — keep this SECRET, only used server-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Open Exchange Rates — get a free App ID at openexchangerates.org
OPENEXCHANGERATES_APP_ID=your-app-id-here
